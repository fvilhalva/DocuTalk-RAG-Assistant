OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=deepseek-r1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
DOCUTALK_DATA_DIR=data
DOCUTALK_CHUNK_SIZE=1200
DOCUTALK_CHUNK_OVERLAP=120
DOCUTALK_TOP_K=4
DOCUTALK_LOG_FILE=interactions.csv

# Optional: safe NVIDIA Docker mode (used by scripts/bootstrap-docker-gpu-safe.sh)
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_MAX_QUEUE=32
OLLAMA_KEEP_ALIVE=20m
